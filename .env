# OpenAI API のバージョン（例: 2024-05-01-preview）
OPENAI_API_VERSION=2024-09-01-preview

# Azure OpenAI 上にデプロイした Chat モデルの名前（例: gpt-4o, gpt-35-turbo など）
AZURE_OPENAI_LLM=gpt-4o-2024-08-06-global

# Azure OpenAI 上にデプロイした Embedding モデルの名前（例: text-embedding-ada-002 など）
AZURE_OPENAI_EMBEDDING=text-embedding-ada-latest


